{
  "name": "@eriveltonsilva/option.js",
  "version": "1.0.0",
  "description": "A lightweight, type-safe library inspired by Rust's `Option` enum for handling optional values in JavaScript and TypeScript without `null` or `undefined` pitfalls.",
  "keywords": [
    "option.js",
    "option",
    "rust",
    "rust-like",
    "rusty"
  ],
  "homepage": "https://github.com/eriveltonsilva/option.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriveltonsilva/option.js.git"
  },
  "license": "MIT",
  "author": {
    "name": "Erivelton Silva",
    "email": "eriveltondasilva13@gmail.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx --bun tsup",
    "dev": "bun run ./src/examples.ts",
    "fix": "bun run types && bun run check:fix",
    "fmt": "bunx --bun @biomejs/biome format .",
    "fmt:fix": "bunx --bun @biomejs/biome format --write .",
    "lint": "bunx --bun @biomejs/biome lint .",
    "lint:fix": "bunx --bun @biomejs/biome lint --write .",
    "check": "bunx --bun @biomejs/biome check .",
    "check:fix": "bunx --bun @biomejs/biome check --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "types": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.12",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "bun@1.0.0+",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
