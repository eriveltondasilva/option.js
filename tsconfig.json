{
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    // Environment setup & latest features
    "types": ["bun"],

    // Some stricter flags (disabled by default)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    // Module resolution
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
